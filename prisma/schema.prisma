generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(cuid())
  name           String
  age            Int       @default(9)
  yearGroup      Int       @default(5)
  avatar         String    @default("🐱") // Emoji or ID
  tutorName      String    @default("Maths Bot")
  theme          String    @default("ocean")
  hobbies        String?
  pets           String?
  currentStreak  Int       @default(0)
  lastSprintDate DateTime?
  sprintDuration Int       @default(900)
  sessions       Session[]
  topics         Topic[]
  rewards        Reward[]
  weeklyInsights WeeklyInsight[]
}

model Topic {
  id              String            @id @default(cuid())
  userId          String
  name            String
  yearGroup       Int               @default(5)
  masteryLevel    Float             @default(0.0)
  difficultyLevel Int               @default(3)
  nextReviewDate  DateTime          @default(now())
  masteredAt      DateTime?
  questionHistory QuestionHistory[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([name, yearGroup, userId])
}

model Session {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime @default(now())
  score    Int
  duration Int
  user     User     @relation(fields: [userId], references: [id])
}

model QuestionHistory {
  id            String   @id @default(cuid())
  topicId       String
  isCorrect     Boolean
  timeTaken     Int
  questionText  String?  // Stores the generated question
  userAnswer    String?  // Stores what the student typed
  correctAnswer String?  // Stores the correct target answer
  misconception String?  // Stores diagnosed error type
  advice        String?  // Advice for that specific error
  answeredAt    DateTime @default(now())
  topic         Topic    @relation(fields: [topicId], references: [id])
}

model Reward {
  id           String    @id @default(cuid())
  userId       String
  title        String
  targetType   String    // 'QUESTIONS_ANSWERED', 'STREAK', 'SPRINTS_COMPLETED', 'MASTERY_LEVEL', 'TIME_SPENT'
  targetValue  Float
  currentValue Float     @default(0.0)
  unlocked     Boolean   @default(false)
  unlockedAt   DateTime?
  claimed      Boolean   @default(false)
  pendingApproval Boolean @default(false)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyInsight {
  id             String   @id @default(cuid())
  userId         String
  weekStart      DateTime
  weekEnd        DateTime
  accuracy       Float
  questionsCount Int
  pointsEarned   Int
  studyTime      Int      // in seconds
  aiAnalysis     String   // AI markdown report
  recsPlan       String   // AI action plan
  encouragement  String   // AI kid note
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
}

